{
  "description": "이미지 파일에 대한 Read 도구 호출을 차단하고 gemini-image-reader 스킬 사용을 강제",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/block-image-read.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
